SubDir HAIKU_TOP src preferences shortcuts ;

UsePrivateHeaders interface ;

local filterSources = [ FDirName $(HAIKU_TOP) src add-ons input_server filters ] ;
UseHeaders $(filterSources) ;

Application Shortcuts :
	main.cpp
	MetaKeyStateMap.cpp
	ShortcutsApp.cpp
	ShortcutsWindow.cpp
	ShortcutsSpec.cpp
	PopUpColumn.cpp
	EditWindow.cpp

	BitFieldTesters.cpp
	CommandActuators.cpp
	KeyInfos.cpp
	ParseCommandLine.cpp

	: be localestub tracker libcolumnlistview.a [ TargetLibstdc++ ]
	: Shortcuts.rdef
;

SEARCH on [ FGristFiles
	BitFieldTesters.cpp
	CommandActuators.cpp
	KeyInfos.cpp
	ParseCommandLine.cpp
] = $(filterSources) ;


DoCatalogs Shortcuts :
	x-vnd.Haiku-Shortcuts
	:
	ShortcutsApp.cpp
	ShortcutsWindow.cpp
	ShortcutsSpec.cpp
;

