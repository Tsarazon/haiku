/*
 * KosmRayTest.rdef
 */

resource app_signature "application/x-vnd.KosmOS-RayTest";

resource app_flags B_SINGLE_LAUNCH;

resource app_version {
	major  = 1,
	middle = 0,
	minor  = 0,

	variety = B_APPV_FINAL,
	internal = 0,

	short_info = "KosmRay Test",
	long_info = "KosmOS Ray IPC Test Suite"
};
