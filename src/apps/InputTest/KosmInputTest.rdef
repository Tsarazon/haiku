/*
 * KosmInputTest.rdef
 */

resource app_signature "application/x-vnd.KosmOS-InputTest";

resource app_flags B_SINGLE_LAUNCH;

resource app_version {
	major  = 1,
	middle = 0,
	minor  = 0,

	variety = B_APPV_FINAL,
	internal = 0,

	short_info = "KosmInput Test",
	long_info = "KosmOS Input Server Devices & Filters Test Suite"
};
