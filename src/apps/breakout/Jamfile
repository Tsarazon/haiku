	BreakoutView.cpp
	:
	be
	libkosmcg.so
	localestub
	[ TargetLibstdc++ ]
	:
	BreakoutGame.rdef
;

DoCatalogs BreakoutGame :
	x-vnd.Haiku-BreakoutGame
	:
	BreakoutGame.cpp
	BreakoutView.cpp
;
