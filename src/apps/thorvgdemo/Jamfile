SubDir HAIKU_TOP src apps thorvgdemo ;

UseLibraryHeaders kosmvg ;
UsePrivateHeaders shared ;
UsePublicHeaders surface ;

SubDirC++Flags -std=c++20 ;

Application ThorVGDemo :
	ThorVGDemo.cpp
	:
	be
	libkosmvg.so
	libsurface.so
	localestub
	[ TargetLibstdc++ ]
	:
	ThorVGDemo.rdef
;

DoCatalogs ThorVGDemo :
	x-vnd.Haiku-ThorVGDemo
	:
	ThorVGDemo.cpp
;