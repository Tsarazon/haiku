SubDir HAIKU_TOP src libs kosmrandom ;

UseLibraryHeaders kosmrandom ;

SubDirC++Flags -std=c++20 ;

local architectureObject ;
for architectureObject in [ MultiArchSubDirSetup ] {
	on $(architectureObject) {
		SharedLibrary [ MultiArchDefaultGristFiles libkosmrandom.so ] :
			KosmRandom.cpp
			:
			[ TargetLibstdc++ ]
			;
	}
}