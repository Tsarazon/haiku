# DK drivers installed at proper module paths. Legacy AddDriversToPackage
# puts files in add-ons/kernel/drivers/bin/, which the module scanner
# explicitly skips — so DK drivers installed that way would never be
# discovered by DiscoverDrivers("drivers"). AddNewDriversToPackage places
# them at add-ons/kernel/drivers/<subdir>/<name> so they're scanned.
AddNewDriversToPackage :
	<driver>pty
	;
AddNewDriversToPackage common :
	console
	dprintf
	null
	usb_modeswitch
	;
# Subdir MUST match the module name path exactly. get_module()
# walks the module name as a filesystem path under add-ons/kernel/
# (see vfs_get_module_path) — mismatched install directories cause
# "No such file or directory" on module load even though
# DiscoverDrivers sees the file and reports its registered name.
# Module names declared by drivers:
#   drivers/audio/hda/... drivers/audio/usb_audio/... → audio
#   drivers/bluetooth/h2generic/... → bluetooth
#   drivers/midi/usb_midi/... → midi
#   drivers/disk/nbd/... → disk  (NOT disk virtual)
#   drivers/network/<name>/... → network  (NOT net)
AddNewDriversToPackage audio :
	$(SYSTEM_ADD_ONS_DRIVERS_AUDIO) ;
AddNewDriversToPackage bluetooth :
	$(SYSTEM_ADD_ONS_DRIVERS_BT_H2) ;
AddNewDriversToPackage midi :
	$(SYSTEM_ADD_ONS_DRIVERS_MIDI) ;
AddNewDriversToPackage bus :
	usb_raw
	;
AddNewDriversToPackage disk virtual :
	nbd
	;
